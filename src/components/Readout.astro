---
// A technical readout — mono key/value pairs of project metadata.
interface Row { k: string; v: string }
interface Props { rows: Row[] }
const { rows } = Astro.props;
---
<dl class="readout">
  {rows.map((row) => (
    <div class="readout__row">
      <dt class="readout__k">{row.k}</dt>
      <dd class="readout__v">{row.v}</dd>
    </div>
  ))}
</dl>

<style>
  .readout {
    display: grid;
    gap: 0;
    border-top: 1px solid var(--hair);
  }
  .readout__row {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 1rem;
    padding-block: 0.7rem;
    border-bottom: 1px solid var(--hair);
  }
  .readout__k {
    font-family: var(--mono);
    font-size: var(--step--2);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--mid);
    padding-top: 0.15rem;
  }
  .readout__v {
    font-family: var(--mono);
    font-size: var(--step--1);
    letter-spacing: 0.02em;
    color: var(--silver);
    line-height: 1.5;
  }
  @media (max-width: 520px) {
    .readout__row { grid-template-columns: 7rem 1fr; gap: 0.6rem; }
  }
</style>
