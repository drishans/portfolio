---
// Small instrument diagrams used as plate ornaments — original line drawings in
// the spirit of an engraved almanac: audio and field-measurement readouts.
// All stroke currentColor so they inherit whatever accent the context sets.
interface Props {
  name?: 'waveform' | 'spectrum' | 'contour' | 'polar' | 'phases';
  size?: number;
  class?: string;
}
const { name = 'waveform', size = 46, class: cls = '' } = Astro.props;
const h = Math.round(size * 0.52);
---
<svg
  class:list={['glyph', cls]}
  width={size}
  height={h}
  viewBox="0 0 46 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1"
  stroke-linecap="round"
  aria-hidden="true"
>
  {name === 'waveform' && (
    <g>
      <line x1="1" y1="12" x2="45" y2="12" stroke-width="0.4" opacity="0.5" />
      {[3,5,7,4,9,11,8,12,6,10,7,5,9,4,6,3].map((v, i) => (
        <line x1={2 + i * 2.8} y1={12 - v} x2={2 + i * 2.8} y2={12 + v} />
      ))}
    </g>
  )}
  {name === 'spectrum' && (
    <g>
      <line x1="1" y1="22" x2="45" y2="22" stroke-width="0.4" opacity="0.5" />
      {[6,10,8,14,11,17,13,9,15,7,12,5].map((v, i) => (
        <line x1={3 + i * 3.6} y1="22" x2={3 + i * 3.6} y2={22 - v} stroke-width="2" />
      ))}
    </g>
  )}
  {name === 'contour' && (
    <g fill="none">
      <path d="M23 4c8 0 14 4 14 8s-6 8-14 8-14-4-14-8 6-8 14-8z" />
      <path d="M23 7c5 0 9 2.5 9 5s-4 5-9 5-9-2.5-9-5 4-5 9-5z" />
      <path d="M23 10c2.6 0 4.5 1 4.5 2s-1.9 2-4.5 2-4.5-1-4.5-2 1.9-2 4.5-2z" />
    </g>
  )}
  {name === 'polar' && (
    <g>
      <path d="M3 21a20 20 0 0 1 40 0" fill="none" />
      <path d="M9 21a14 14 0 0 1 28 0" fill="none" opacity="0.7" />
      <path d="M15 21a8 8 0 0 1 16 0" fill="none" opacity="0.5" />
      <line x1="23" y1="21" x2="23" y2="1" stroke-width="0.5" />
      <line x1="23" y1="21" x2="6" y2="11" stroke-width="0.5" />
      <line x1="23" y1="21" x2="40" y2="11" stroke-width="0.5" />
      <path d="M23 21c-7-3-9-9-6-13 4 5 9 4 12 0 3 4 1 10-6 13z" fill="currentColor" opacity="0.18" stroke="none" />
    </g>
  )}
  {name === 'phases' && (
    <g>
      <circle cx="6" cy="12" r="4" fill="none" opacity="0.5" />
      <path d="M16 8a4 4 0 0 1 0 8z" fill="currentColor" stroke="none" />
      <circle cx="16" cy="12" r="4" fill="none" />
      <circle cx="26" cy="12" r="4" fill="currentColor" stroke="none" />
      <path d="M36 8a4 4 0 0 0 0 8z" fill="currentColor" stroke="none" />
      <circle cx="36" cy="12" r="4" fill="none" />
      <circle cx="40" cy="12" r="0.5" fill="none" opacity="0" />
    </g>
  )}
</svg>

<style>
  .glyph { display: block; color: var(--mid); }
</style>
