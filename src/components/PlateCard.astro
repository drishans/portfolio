---
// Project card — renders a numbered "PLATE" in the field guide.
import Glyph from './Glyph.astro';
interface Props {
  plate: string; // zero-padded, e.g. "01"
  title: string;
  summary: string;
  role: string;
  year: number;
  stack?: string[];
  href: string;
  glyph?: 'waveform' | 'spectrum' | 'contour' | 'polar' | 'phases';
}
const { plate, title, summary, role, year, stack = [], href, glyph = 'waveform' } = Astro.props;
---

<a class="plate" href={href}>
  <div class="plate__top">
    <span class="plate__no">PLATE {plate}</span>
    <span class="plate__year">{year}</span>
  </div>

  <div class="plate__glyph"><Glyph name={glyph} size={50} /></div>

  <div class="plate__body">
    <h3 class="plate__title">{title}</h3>
    <p class="plate__summary">{summary}</p>
  </div>

  <div class="plate__foot">
    <span class="plate__role">{role}</span>
    {stack.length > 0 && (
      <span class="plate__stack">{stack.slice(0, 3).join(' · ')}</span>
    )}
  </div>

  <span class="plate__go" aria-hidden="true">→</span>
</a>

<style>
  .plate {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 17.5rem;
    padding: 1.1rem 1.2rem 1.2rem;
    background: var(--ink-2);
    border: 1px solid var(--hair);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.25s var(--ease), background 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .plate:hover {
    border-color: var(--hair-bright);
    background: var(--ink-3);
    transform: translateY(-2px);
  }
  .plate__top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: var(--mono);
    font-size: var(--step--2);
    letter-spacing: 0.14em;
  }
  .plate__no { color: var(--signal); font-weight: 600; }
  .plate__year { color: var(--mid); }

  /* the instrument diagram — faint, lifts to signal on hover */
  .plate__glyph {
    position: absolute;
    top: 2.6rem; right: 1.2rem;
    color: var(--mid);
    opacity: 0.55;
    transition: color 0.25s var(--ease), opacity 0.25s var(--ease);
  }
  .plate:hover .plate__glyph { color: var(--signal); opacity: 1; }

  .plate__body { margin-top: auto; padding-top: 2.4rem; }
  .plate__title {
    font-size: var(--step-2);
    font-variation-settings: 'opsz' 60, 'wght' 540, 'SOFT' 0, 'WONK' 0;
    line-height: 1.06;
  }
  .plate__summary {
    margin-top: 0.6rem;
    color: var(--silver-dim);
    font-size: var(--step--1);
    line-height: 1.55;
    max-width: 38ch;
  }

  .plate__foot {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 0.9rem;
    margin-top: 1.1rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--hair);
    font-family: var(--mono);
    font-size: var(--step--2);
    letter-spacing: 0.08em;
    color: var(--mid);
  }
  .plate__role { color: var(--silver-dim); }

  .plate__go {
    position: absolute;
    bottom: 1.2rem; right: 1.2rem;
    color: var(--signal);
    font-size: 1.1rem;
    transform: translateX(-4px);
    opacity: 0;
    transition: opacity 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .plate:hover .plate__go { opacity: 1; transform: translateX(0); }
</style>
