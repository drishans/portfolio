---
import Base from '../../layouts/Base.astro';
import { getPublished } from '../../utils';
import { SITE, TOPICS, type TopicSlug } from '../../consts';

const work = await getPublished('work');
const writing = await getPublished('writing');

// Only topics with published content get a hub (and a row here).
const live = (Object.keys(TOPICS) as TopicSlug[])
  .map((slug) => ({
    slug,
    name: TOPICS[slug],
    count:
      work.filter((w) => w.data.topics.includes(slug)).length +
      writing.filter((p) => p.data.topics.includes(slug)).length,
  }))
  .filter((t) => t.count > 0);
---

<Base title={`Topics — ${SITE.author}`} description="The field guide by subject: quantum, audio, compilers, scientific computing, and the rest of the bench.">
  <section class="section">
    <div class="wrap">
      <header class="top">
        <p class="eyebrow">Topics</p>
        <h1 class="top__title">By subject</h1>
        <p class="top__sub measure">
          The same specimens, filed by field — plates and notes sorted into the
          subjects they belong to.
        </p>
      </header>

      <div class="topics">
        {live.map((t) => (
          <a class="topic" href={`/topics/${t.slug}/`}>
            <span class="topic__name">{t.name}</span>
            <span class="topic__count mono">{t.count} {t.count === 1 ? 'entry' : 'entries'}</span>
            <span class="topic__go" aria-hidden="true">→</span>
          </a>
        ))}
      </div>

      {live.length === 0 && (
        <p class="empty">Nothing filed yet. The cabinets are on order.</p>
      )}
    </div>
  </section>
</Base>

<style>
  .top { margin-bottom: var(--s-6); }
  .top__title { font-size: var(--step-4); margin-top: 0.4rem; }
  .top__sub { margin-top: 1.1rem; color: var(--silver-dim); font-size: var(--step-0); line-height: 1.6; }

  .topics { border-bottom: 1px solid var(--hair); max-width: var(--measure); }
  .topic {
    display: grid;
    grid-template-columns: 1fr auto 1.4rem;
    align-items: baseline;
    gap: 1rem;
    padding-block: 1.1rem;
    border-top: 1px solid var(--hair);
    transition: border-color 0.2s var(--ease);
  }
  .topic:hover { border-top-color: var(--signal); }
  .topic__name {
    font-family: var(--display);
    font-variation-settings: 'opsz' 40, 'wght' 520, 'SOFT' 0, 'WONK' 0;
    font-size: var(--step-1);
    color: var(--silver);
    transition: color 0.2s var(--ease);
  }
  .topic:hover .topic__name { color: var(--signal); }
  .topic__count { color: var(--mid); }
  .topic__go {
    color: var(--signal);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.2s var(--ease), transform 0.2s var(--ease);
  }
  .topic:hover .topic__go { opacity: 1; transform: translateX(0); }

  .empty { color: var(--silver-dim); font-style: italic; }
</style>
